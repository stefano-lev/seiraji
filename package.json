  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/stefano-lev/seiraji/issues"
  },
  "homepage": "https://github.com/stefano-lev/seiraji#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
